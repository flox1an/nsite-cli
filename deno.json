{
  "name": "@nsyte/cli",
  "version": "0.23.1",
  "description": "nsyte - publish your site to nostr and blossom servers",
  "license": "MIT",
  "exports": "./src/cli.ts",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-net --allow-env --allow-sys src/cli.ts",
    "test": "deno test --allow-all --no-check",
    "test:unit": "deno test --allow-all --no-check tests/unit/",
    "test:integration": "deno test --allow-all --no-check tests/integration/",
    "test:fast": "timeout 60 deno test --allow-all --no-check tests/unit/config_test.ts tests/unit/logger_test.ts",
    "coverage": "deno test --allow-read --allow-write --allow-net --allow-env --allow-import --coverage=test-output/coverage --no-check",
    "coverage:badge": "deno run --allow-read --allow-write --allow-run scripts/generate-coverage-badge.ts",
    "coverage:report": "deno task coverage && deno task coverage:badge",
    "version": "deno run --allow-read --allow-write --allow-env scripts/sync-version.ts",
    "compile": "deno compile --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --output dist/nsyte src/cli.ts",
    "compile:all": "deno task compile:linux && deno task compile:macos && deno task compile:windows",
    "compile:linux": "deno compile --no-check --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --target x86_64-unknown-linux-gnu --output dist/nsyte-linux src/cli.ts",
    "compile:macos": "deno compile --no-check --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --target x86_64-apple-darwin --output dist/nsyte-macos src/cli.ts",
    "compile:windows": "deno compile --no-check --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --target x86_64-pc-windows-msvc --output dist/nsyte-windows.exe src/cli.ts",
    "compile:linux:production": "deno compile --no-check --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --target x86_64-unknown-linux-gnu --output dist/nsyte-linux src/cli.ts",
    "compile:macos:production": "deno compile --no-check --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --target x86_64-apple-darwin --output dist/nsyte-macos src/cli.ts",
    "compile:windows:production": "deno compile --no-terminal --no-check --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --target x86_64-pc-windows-msvc --output dist/nsyte-windows.exe src/cli.ts",
    "compile:all:production": "deno task compile:linux:production && deno task compile:macos:production && deno task compile:windows:production",
    "compress": "cp dist/nsyte dist/nsyte-compressed && upx --best --lzma dist/nsyte-compressed",
    "compress:linux": "cp dist/nsyte-linux dist/nsyte-linux-compressed && upx --best --lzma dist/nsyte-linux-compressed",
    "compress:macos": "cp dist/nsyte-macos dist/nsyte-macos-compressed && upx --best --lzma --force-macos dist/nsyte-macos-compressed",
    "compress:windows": "cp dist/nsyte-windows.exe dist/nsyte-windows-compressed.exe && upx --best --lzma dist/nsyte-windows-compressed.exe",
    "compress:all": "deno task compress:linux && deno task compress:macos && deno task compress:windows",
    "build:compressed": "deno task compile && deno task compress",
    "build:compressed:linux": "deno task compile:linux:production && deno task compress:linux",
    "build:compressed:macos": "deno task compile:macos:production && deno task compress:macos",
    "build:compressed:windows": "deno task compile:windows:production && deno task compress:windows",
    "build:compressed:all": "deno task compile:all:production && deno task compress:all",
    "install": "deno task compile && chmod +x dist/nsyte && rm /usr/local/bin/nsyte && mv dist/nsyte /usr/local/bin/nsyte",
    "tag": "deno run --allow-read --allow-write --allow-run=git scripts/tag.ts",
    "release": "deno run --allow-read --allow-run=git --allow-net scripts/release.ts",
    "docs:build": "./scripts/build-docs.sh",
    "docs:serve": "./scripts/serve-docs.sh",
    "site:build": "./scripts/build-site.sh",
    "site:serve": "./scripts/serve-site.sh",
    "serve": "deno run --allow-net --allow-read https://deno.land/std@0.220.0/http/file_server.ts --port=8000 .",
    "serve:dist": "deno run --allow-net --allow-read https://deno.land/std@0.220.0/http/file_server.ts --port=8000 ./dist"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0-rc.8",
    "@cliffy/command": "jsr:@cliffy/command@1.0.0-rc.8",
    "@cliffy/prompt": "jsr:@cliffy/prompt@1.0.0-rc.8",
    "@cliffy/keypress": "jsr:@cliffy/keypress@1.0.0-rc.8",
    "@libs/qrcode": "jsr:@libs/qrcode@^3.0.1",
    "@nick/brotli": "jsr:@nick/brotli@0.1.0",
    "@std/assert": "jsr:@std/assert@^1.0.18",
    "@std/http": "jsr:@std/http@^1.0.24",
    "@std/fs": "jsr:@std/fs@^1.0.22",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "ajv": "npm:ajv@8.17.1",
    "ajv-formats": "npm:ajv-formats@3.0.1",
    "applesauce-common": "npm:applesauce-common@^5.1.0",
    "applesauce-core": "npm:applesauce-core@^5.1.0",
    "applesauce-loaders": "npm:applesauce-loaders@^5.1.0",
    "applesauce-relay": "npm:applesauce-relay@^5.1.0",
    "applesauce-signers": "npm:applesauce-signers@^5.1.0",
    "rxjs": "npm:rxjs@^7.8.2",
    "@noble/curves": "npm:@noble/curves@^1.9.7",
    "@noble/hashes": "npm:@noble/hashes@^1.8.0",
    "@scure/base": "npm:@scure/base@^1.2.6",
    "@scure/bip32": "npm:@scure/bip32@^1.7.0",
    "@scure/bip39": "npm:@scure/bip39@^1.6.0"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "test": {
    "include": [
      "tests/"
    ]
  }
}
